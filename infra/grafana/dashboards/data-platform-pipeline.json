{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "Data Platform Pipeline",
  "tags": ["smartforge", "data-platform", "pipeline"],
  "time": { "from": "now-24h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "Last Run Success Rate",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 } },
      "targets": [{ "expr": "smartforge_pipeline_last_run_success_ratio" }]
    },
    {
      "type": "stat",
      "title": "Last Run Rows Migrated",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "smartforge_pipeline_last_run_rows" }]
    },
    {
      "type": "stat",
      "title": "Last Run Data Volume",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [{ "expr": "smartforge_pipeline_last_run_bytes" }]
    },
    {
      "type": "stat",
      "title": "Last Run Throughput",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "targets": [{ "expr": "smartforge_pipeline_last_run_bytes_per_second" }]
    },
    {
      "type": "stat",
      "title": "Last Run Duration",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [{ "expr": "smartforge_pipeline_last_run_duration_seconds" }]
    },
    {
      "type": "stat",
      "title": "Last Run Row Throughput",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "rowsps" } },
      "targets": [{ "expr": "smartforge_pipeline_last_run_rows_per_second" }]
    },
    {
      "type": "stat",
      "title": "Time Since Last Run",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "time() - smartforge_pipeline_last_run_timestamp_seconds" }
      ]
    },
    {
      "type": "stat",
      "title": "Failed Table Syncs (24h)",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 6 },
      "targets": [
        {
          "expr": "sum(increase(smartforge_pipeline_table_syncs_total{status=\"failed\"}[24h]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Data Bandwidth (published Parquet bytes/s, 5m rate)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "targets": [
        {
          "expr": "sum by (kind) (rate(smartforge_pipeline_bytes_total[5m]))",
          "legendFormat": "{{kind}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Row Throughput (rows/s, 5m rate)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum by (kind) (rate(smartforge_pipeline_rows_total[5m]))",
          "legendFormat": "{{kind}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Stage Duration p95 (s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, stage) (rate(smartforge_pipeline_stage_duration_seconds_bucket[1h])))",
          "legendFormat": "{{stage}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Run Success vs Failure (per hour)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "sum by (kind, status) (increase(smartforge_pipeline_runs_total[1h]))",
          "legendFormat": "{{kind}} {{status}}"
        }
      ]
    }
  ]
}
