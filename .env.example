# =============================================================================
# SmartForge v1.0.0 — environment template
# =============================================================================
# Copy to .env and set real values. NEVER commit .env (git-ignored; gitleaks
# scans CI). Generate strong secrets with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# Enforcement: values left as "changethis" are refused outside local
# environments; the data-platform `cli preflight` additionally gates every
# platform credential before any pipeline operation (CICD-011).
# Values marked SANDBOX are the documented demo logins (README/tests) —
# rotate them for any shared, staging, or production environment.

# -----------------------------------------------------------------------------
# Deployment identity (Traefik routing / TLS / image tags)
# -----------------------------------------------------------------------------
DOMAIN=localhost
# Backend-generated email links point at the frontend
FRONTEND_HOST=http://localhost:5173
# Environment: local, staging, production
ENVIRONMENT=local
PROJECT_NAME="SmartForge"
STACK_NAME=smartforge
# Image coordinates used by compose (CI overrides TAG per release)
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend
TAG=latest

# -----------------------------------------------------------------------------
# Security & authentication (application)
# -----------------------------------------------------------------------------
SECRET_KEY=changethis
FIRST_SUPERUSER=smartforge@futureform.com
# SANDBOX — documented demo superuser login; rotate outside local
FIRST_SUPERUSER_PASSWORD=futureform2026
# Comma-separated allowed origins for browser clients
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,http://localhost:5174"
# Host-header allowlist ("*" = disabled; set real hosts in staging/production,
# e.g. "api.example.com,dashboard.example.com")
ALLOWED_HOSTS=*
# Traefik per-client rate limiting on the API router (SEC-012 / API-017)
API_RATE_LIMIT_AVERAGE=100
API_RATE_LIMIT_BURST=200
# App-layer role-aware rate limiting (SEC-012 / API-017) — per-process token
# buckets keyed by user identity; Traefik's coarse per-IP limit above is separate.
RATE_LIMIT_ENABLED=true
# Per-minute budgets by tier (per backend worker process)
RATE_LIMIT_SUPERUSER_PER_MINUTE=600
RATE_LIMIT_INTERNAL_PER_MINUTE=300
RATE_LIMIT_CUSTOMER_PER_MINUTE=120
# Anonymous requests are bucketed per client IP (strictest tier)
RATE_LIMIT_ANONYMOUS_PER_MINUTE=30
# Site-wide feature-flag overrides (app/core/features.py): comma-separated
# feature keys force-enabled/disabled regardless of user tier. Overrides
# never bypass authentication or the customer/internal boundary.
FEATURE_FLAGS_ENABLE=
FEATURE_FLAGS_DISABLE=
# Interactive API docs (/docs Swagger UI, /redoc ReDoc, /api/v1/openapi.json).
# On by default in every environment; set false to withdraw the surface.
API_DOCS_ENABLED=true
# Optional bearer token for the Prometheus scrape endpoint (/api/v1/metrics).
# Empty = open for in-network scrapers; set when the port is exposed wider.
METRICS_BEARER_TOKEN=

# -----------------------------------------------------------------------------
# Application database (PostgreSQL — transactional app)
# -----------------------------------------------------------------------------
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

# -----------------------------------------------------------------------------
# Email (optional — Mailcatcher is auto-wired in local compose)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
EMAILS_FROM_NAME="SmartForge"
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# -----------------------------------------------------------------------------
# Observability & sandbox accounts
# -----------------------------------------------------------------------------
SENTRY_DSN=
# Grafana admin (loopback-only in compose; still set a real value)
GRAFANA_PASSWORD=changethis
# SANDBOX — seeded demo accounts (operator@smartforge.com, buyer@acme-robotics.com)
SANDBOX_USER_PASSWORD=futureform2026

# -----------------------------------------------------------------------------
# SmartForge application services
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
# Set when Redis requires AUTH (managed Redis); compose's local redis has none
REDIS_PASSWORD=
# ForgeAI vector store (compose wires http://qdrant:6333 automatically)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
# Set to enable real Claude-powered ForgeAI; blank = deterministic offline fallback
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# Mock Fiix CMMS adapter (replace with the real endpoint + key when integrating)
FIIX_BASE_URL=https://mock.fiix.local/api
FIIX_API_KEY=
# Telemetry simulator (compose runs it in the dedicated `worker` service)
SIMULATOR_ENABLED=true
SIMULATOR_INTERVAL_SECONDS=3

# -----------------------------------------------------------------------------
# Frontend (build-time)
# -----------------------------------------------------------------------------
# Baked into the frontend bundle at build time. Compose derives it from DOMAIN
# (https://api.${DOMAIN}); local `bun run dev` falls back to localhost:8000.
# VITE_API_URL=http://localhost:8000

# =============================================================================
# Data Platform (omega Oracle -> Parquet lake -> DuckDB + PostgreSQL warehouse)
# Setup walkthrough: QUICKSTART.md · governance: docs/data-platform.md
# =============================================================================

# ---- Omega database (Oracle source) — READ-ONLY extraction identity ----
# Must be a dedicated analytics account with CREATE SESSION + SELECT (and
# FLASHBACK for SCN-consistent seeds) only — grant template in QUICKSTART.md
# Part 1. Never reuse an application-owner or APEX account (ORA-001); a
# writable identity is refused at every connect (ORA-003).
OMEGA_ORACLE_USER=omega_analytics_reader
OMEGA_ORACLE_PASSWORD=changethis
OMEGA_ORACLE_HOST=omega-db.internal
OMEGA_ORACLE_PORT=1521
# Service name is preferred; set OMEGA_ORACLE_SID only for legacy SID connects
# (SID takes precedence when non-empty).
OMEGA_ORACLE_SERVICE_NAME=OMEGAPDB1
OMEGA_ORACLE_SID=
# Comma-separated schemas approved for extraction
OMEGA_ORACLE_SCHEMAS=OMEGA
# Enable when the listener supports TCPS (exception E1 closure)
OMEGA_ORACLE_TLS_ENABLED=false
# Keep the pool small: we are a tenant on the transactional system (ORA-007)
OMEGA_ORACLE_POOL_MIN=1
OMEGA_ORACLE_POOL_MAX=4
OMEGA_ORACLE_CALL_TIMEOUT_SECONDS=900
OMEGA_ORACLE_FETCH_ARRAYSIZE=50000

# ---- Canonical Parquet lake + DuckDB catalog ----
# In compose these live on the app-lake-data volume (/srv/data/...)
LAKE_ROOT=./data/lake
DUCKDB_PATH=./data/catalog/smartforge_lake.duckdb
DUCKDB_MEMORY_LIMIT=2GB
DUCKDB_THREADS=4
PARQUET_COMPRESSION=zstd
PARQUET_TARGET_FILE_MB=256
LAKE_RETAINED_SNAPSHOTS=3

# ---- PostgreSQL warehouse (separate database, role-separated identities) ----
WAREHOUSE_DB=warehouse
WAREHOUSE_LOADER_USER=warehouse_loader
WAREHOUSE_LOADER_PASSWORD=changethis
WAREHOUSE_DBT_USER=warehouse_transformer
WAREHOUSE_DBT_PASSWORD=changethis
WAREHOUSE_API_USER=warehouse_api_reader
WAREHOUSE_API_PASSWORD=changethis

# ---- Platform ownership & governance ----
# Accountable owner recorded on dbt exposures, alerts, and governance docs.
PLATFORM_OWNER_EMAIL=admin@futureform.com

# ---- Scheduled database backups (db-backup service; PG-009 / DR-002) ----
# Cron-style or @daily/@hourly. Restore procedure: runbooks/backup_restore.md
BACKUP_SCHEDULE=@daily
BACKUP_KEEP_DAYS=7
BACKUP_KEEP_WEEKS=4
BACKUP_KEEP_MONTHS=6

# ---- Pipeline behaviour ----
# development | staging | production. Outside development: known-default
# platform credentials refuse process start (settings-load validator) and
# `cli preflight` fails empty ones (CICD-013).
PLATFORM_ENV=development
# When true (always in production), seeding requires an operator-confirmed
# plan + confirmation phrase (discovery -> review -> confirm).
SEED_REQUIRE_CONFIRMATION=true
# Single-flight advisory lock TTL; also the abandoned-staging sweep threshold
PIPELINE_LOCK_TTL_SECONDS=3600
# Prometheus scrape port on the platform-worker (pipeline throughput, stage
# durations, migration success KPIs — Grafana "Data Platform Pipeline"
# dashboard). 0 disables the exporter.
PLATFORM_METRICS_PORT=9108
# Governed API guardrails (warehouse statement timeout also bounds lake queries)
API_MAX_PAGE_SIZE=1000
API_STATEMENT_TIMEOUT_MS=15000
# Freshness thresholds (dead-man's switch; minutes)
FRESHNESS_HOURLY_WARN_MINUTES=75
FRESHNESS_HOURLY_ERROR_MINUTES=120
FRESHNESS_DAILY_WARN_MINUTES=1560
FRESHNESS_DAILY_ERROR_MINUTES=1800

# =============================================================================
# Advanced tuning — sensible code defaults; uncomment to override
# =============================================================================
# LOG_LEVEL=INFO                           # every service (API, workers, CLI)
# ACCESS_TOKEN_EXPIRE_MINUTES=720          # JWT lifetime (12 hours)
# EMAIL_RESET_TOKEN_EXPIRE_HOURS=48
# ANTHROPIC_MAX_TOKENS=1024                # ForgeAI response budget
# RAG_ENABLED=true                         # vector retrieval on/off
# RAG_TOP_K=5                              # sources cited per answer
# RAG_CANDIDATES=20                        # retrieval candidate pool
# RAG_RERANK=true
# EMBED_MODEL=BAAI/bge-small-en-v1.5
# RERANK_MODEL=Xenova/ms-marco-MiniLM-L-6-v2
# QDRANT_COLLECTION=knowledge_bases
# TELEMETRY_FRESH_SECONDS=30               # machine "live" threshold
# ALERT_TEMP_LIMIT=85.0                    # alert-rule thresholds
# ALERT_VIBRATION_LIMIT=0.6
# ALERT_RUNTIME_LIMIT=2000.0
# ALERT_HEALTH_FLOOR=60.0
# ESCALATION_CONFIDENCE_THRESHOLD=0.5      # AI answer -> human escalation
# QUOTE_MATERIAL_RATE=3.5                  # quoting economics
# QUOTE_MACHINE_RATE=0.85
# QUOTE_LABOR_RATE=12.0
# QUOTE_RUSH_MULTIPLIER=0.25
# QUOTE_TARGET_MARGIN=0.35
# SCRAP_UNIT_COST=42.0
# REWORK_UNIT_COST=18.0
