# Copy to .env and fill in real values. Do NOT commit secrets.

# Domain (Traefik routing / TLS)
DOMAIN=localhost

# Backend-generated email links to the frontend
FRONTEND_HOST=http://localhost:5173

# Environment: local, staging, production
ENVIRONMENT=local

PROJECT_NAME="SmartForge"
STACK_NAME=smartforge

# Backend
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,http://localhost:5174"
SECRET_KEY=changethis
FIRST_SUPERUSER=smartforge@futureform.com
FIRST_SUPERUSER_PASSWORD=futureform2026

# Emails (optional)
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# Postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

SENTRY_DSN=

# Docker images
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend

# ---- SmartForge ----
REDIS_HOST=localhost
REDIS_PORT=6379
# Set to enable real Claude-powered AskAI; blank = deterministic offline fallback
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# Mock Fiix CMMS adapter
FIIX_BASE_URL=https://mock.fiix.local/api
FIIX_API_KEY=
# Telemetry simulator (run in-process; the compose `worker` service runs it instead)
SIMULATOR_ENABLED=true
SIMULATOR_INTERVAL_SECONDS=3
# Observability + sandbox accounts
GRAFANA_PASSWORD=admin
SANDBOX_USER_PASSWORD=futureform2026
