# ───────────────────────────────────────────────────────────────────────────
# future-form — consolidated ignore rules (covers everything under src/)
# Patterns are unanchored so they match in backend/, frontend/, and the root.
# ───────────────────────────────────────────────────────────────────────────

# ── Secrets — never commit. (.env.example is the committed template.) ─────────
.env
.env.*
!.env.example
*.pem
*.key

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
app.egg-info/
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.cache/

# ── Node / frontend ──────────────────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Generated API client / schema
openapi.json

# ── Test & E2E artifacts (Playwright / Vitest) ───────────────────────────────
test-results/
test-results;*/
playwright-report/
blob-report/
playwright/.cache/
playwright/.auth/

# ── Editor / OS ──────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
